rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the request is from an authenticated admin
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Public read-only collections (for website rendering)
    match /plans/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /faq/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /testimonials/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /coverage/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /services/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /hero_banners/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /settings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /offers/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Enquiries: Anyone can submit a lead form; only admins can view/manage them
    match /enquiries/{document} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Admins registry access control
    match /admins/{adminId} {
      allow read: if request.auth != null;
      // Allow bootstrapping the first admin document if it doesn't exist yet
      allow write: if isAdmin() || (request.auth != null && request.auth.uid == adminId && !exists(/databases/$(database)/documents/admins/$(adminId)));
    }
  }
}
